{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch YARR",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/yarr/main.go",
            "env": {
                "YARR_ADDR": "127.0.0.1:7070",
                "YARR_DB": "${workspaceFolder}/yarr.db"
            },
            "args": [],
            // 编译时强制禁用优化和内联，保证调试信息完整
            "buildFlags": "-gcflags='all=-N -l'",
            "showLog": true
        }
    ]
}